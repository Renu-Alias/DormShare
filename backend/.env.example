# Example environment variables for backend
# Copy this to .env and fill in values. DO NOT commit secrets.

# Server
PORT=5000
NODE_ENV=development

# Primary (SRV) MongoDB URI (preferred when allowed):
# Example: mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=

# Non-SRV (standard) MongoDB URI - fallback when SRV lookups fail in this Node runtime
MONGO_URI_NON_SRV=

# Local fallback for development
MONGO_URI_FALLBACK=mongodb://127.0.0.1:27017/dormshare_dev

# DB retry behavior
DB_MAX_RETRIES=5
DB_RETRY_BASE_MS=2000
DB_RECONNECT_INTERVAL_MS=60000
# If true, process exits if DB cannot be reached after retries
DB_FAIL_FAST=false

# CORS origin (frontend)
CORS_ORIGIN=http://localhost:5173

# JWT and email placeholders
JWT_SECRET=
FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
PORT=5000
NODE_ENV=development
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret_key_min_32_chars

CORS_ORIGIN=http://localhost:5173
JWT_EXPIRE=7d
# Comma-separated. Leave empty to allow any email domain (for development).
ALLOWED_EMAIL_DOMAINS=@mits.ac.in
FROM_EMAIL=your_email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password